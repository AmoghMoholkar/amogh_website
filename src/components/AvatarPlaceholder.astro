---
// Swap this out once you have a real photo:
// 1. Drop your image at /public/images/profile.jpg
// 2. Replace the <div class="avatar-placeholder"> block below with:
//      <img src={`${import.meta.env.BASE_URL}images/profile.jpg`} alt="[Your name]" class="avatar-photo" />
interface Props { initials?: string; size?: number; }
const { initials = 'AK', size = 260 } = Astro.props;
---

<div class="avatar-placeholder" style={`--size:${size}px`} role="img" aria-label="Photo placeholder">
  <svg viewBox="0 0 100 100" width="100%" height="100%" aria-hidden="true">
    <polygon points="50,4 90,27 90,73 50,96 10,73 10,27" fill="none" stroke="currentColor" stroke-width="1" opacity="0.5" />
    <polygon points="50,20 74,34 74,66 50,80 26,66 26,34" fill="none" stroke="currentColor" stroke-width="0.7" opacity="0.35" />
  </svg>
  <span class="initials">{initials}</span>
</div>

<style>
  .avatar-placeholder {
    position: relative;
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    border: 1px dashed var(--line-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--patina);
    background: var(--bg-elevated);
    overflow: hidden;
  }
  .avatar-placeholder svg { position: absolute; inset: 0; }
  .initials {
    position: relative;
    font-family: var(--font-display);
    font-size: calc(var(--size) * 0.22);
    color: var(--ink-soft);
  }
</style>

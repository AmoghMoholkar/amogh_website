---
// One orchestrated page-load moment: a hand-drawn-feeling curve that reads as
// a stress-strain curve to an engineer and a plucked-string decay to a
// musician. Draws once on load via stroke-dashoffset, then settles.
---

<svg class="hero-curve" viewBox="0 0 520 220" fill="none" aria-hidden="true">
  <line x1="0" y1="200" x2="520" y2="200" stroke="var(--line)" stroke-width="1" />
  <line x1="10" y1="0" x2="10" y2="210" stroke="var(--line)" stroke-width="1" />
  <path
    id="curve-path"
    d="M10,200 C 60,150 90,95 120,80 C 160,60 190,58 220,66 C 270,80 310,110 360,130 C 410,148 460,155 510,158"
    stroke="var(--patina)"
    stroke-width="2.5"
    stroke-linecap="round"
  />
  <circle cx="120" cy="80" r="3.5" fill="var(--brass)" />
</svg>

<style>
  .hero-curve { width: 100%; height: auto; color: var(--ink); }
  #curve-path {
    stroke-dasharray: 900;
    stroke-dashoffset: 900;
    animation: draw 1800ms ease-out 200ms forwards;
  }
  @keyframes draw {
    to { stroke-dashoffset: 0; }
  }
</style>

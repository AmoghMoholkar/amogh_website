---
// A recurring visual signature: a faceted horizontal line standing in for a
// grain boundary under a micrograph, with small "triple junction" dots at a
// few vertices. Used in place of a plain <hr> between major sections.
---

<svg class="divider-svg" viewBox="0 0 1200 28" preserveAspectRatio="none" aria-hidden="true">
  <polyline
    points="0,14 90,9 180,18 260,11 340,16 430,7 520,17 610,10 700,15 790,8 880,18 970,12 1060,16 1150,9 1200,14"
    fill="none"
    stroke="currentColor"
    stroke-width="1"
    opacity="0.6"
  />
  <circle cx="260" cy="11" r="1.6" fill="currentColor" opacity="0.8" />
  <circle cx="610" cy="10" r="1.6" fill="currentColor" opacity="0.8" />
  <circle cx="970" cy="12" r="1.6" fill="currentColor" opacity="0.8" />
</svg>

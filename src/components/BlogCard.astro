---
interface Props {
  href: string;
  title: string;
  date: Date;
  category: string;
  excerpt: string;
  tags: string[];
}
const { href, title, date, category, excerpt, tags } = Astro.props;
---

<a href={href} class="card blog-card">
  <div class="eyebrow">{category} · <time datetime={date.toISOString()}>{date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time></div>
  <h3>{title}</h3>
  <p>{excerpt}</p>
  <div class="tags">
    {tags.map((t) => <span class="tag tag-outline">#{t}</span>)}
  </div>
</a>

<style>
  .blog-card { display: block; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: var(--space-2); }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import GrainDivider from '../components/GrainDivider.astro';
import SocialIcons from '../components/SocialIcons.astro';
import site from '../data/site.json';

const mapQuery = encodeURIComponent(site.location);
---

<BaseLayout title="Contact" description="Get in touch.">
  <section class="wrap">
    <div class="eyebrow">Contact</div>
    <h1>Get in touch</h1>
    <p class="prose">
      The fastest way to reach me is email. I'm also around on the platforms below.
    </p>

    <div class="contact-grid">
      <div class="reveal">
        <div class="stack">
          <div>
            <div class="eyebrow">Email</div>
            <a href={`mailto:${site.email}`} style="color:var(--patina); font-size:1.1rem;">{site.email}</a>
          </div>
          <div>
            <div class="eyebrow">Location</div>
            <p style="margin:0;">{site.location}</p>
          </div>
          <div>
            <div class="eyebrow">Elsewhere</div>
            <SocialIcons />
          </div>
        </div>

        <div class="map-placeholder">
          <!--
            No API key needed for this basic embed. Replace `site.location`
            in src/data/site.json with your city, or swap this iframe for a
            full Google Maps Embed API / Platform embed if you want more
            control (marker styling, zoom, etc.).
          -->
          <iframe
            title="Location map"
            src={`https://maps.google.com/maps?q=${mapQuery}&z=10&output=embed`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>

      <div class="reveal">
        <div class="eyebrow">Send a message</div>
        <!--
          This form posts to Formspree (https://formspree.io) — free for
          static sites like GitHub Pages, no backend required.
          1. Create a free Formspree account and a new form.
          2. Replace YOUR_FORM_ID below with the ID Formspree gives you.
        -->
        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="contact-form">
          <div class="field">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" required />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required />
          </div>
          <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send message</button>
        </form>
      </div>
    </div>
  </section>

  <div class="wrap"><GrainDivider /></div>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin-top: var(--space-4);
  }
  @media (max-width: 780px) { .contact-grid { grid-template-columns: 1fr; } }
  .map-placeholder {
    margin-top: var(--space-3);
    aspect-ratio: 4/3;
    border: 1px solid var(--line);
    overflow: hidden;
  }
  .map-placeholder iframe { width: 100%; height: 100%; border: 0; }
</style>

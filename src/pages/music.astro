---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GrainDivider from '../components/GrainDivider.astro';
import MusicCard from '../components/MusicCard.astro';

const entries = (await getCollection('music')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Music" description="Guitar covers, tone experiments, and collaborations.">
  <section class="wrap">
    <div class="eyebrow">Music</div>
    <h1>Guitar, tone, and collaboration</h1>
    <p class="prose">
      I play acoustic and electric guitar — mostly recording covers, chasing tone, and covering songs
      with my friends. Tasteful playing over shredding, always. My biggest musical influence is Tommy Emmanuel, CGP, whose musicianship and ability to make a single guitar sound like an entire band continues to inspire me.
I'm also a lifelong admirer of The Beatles, especially George Harrison for his tasteful songwriting and understated guitar work.
Blues has been another major influence on my playing, with legends like Stevie Ray Vaughan, Jimi Hendrix, Eric Clapton, and B.B. King shaping how I think about phrasing, feel, and tone.
    </p>
  </section>

  <section class="wrap">
    <div class="grid grid-2">
      <div class="reveal">
        <h2>Influences</h2>
        <p class="muted">[Add the players and records that shaped your playing.]</p>
      </div>
      <div class="reveal">
        <h2>Equipment</h2>
        <div class="stack">
          <p><strong>Guitars:</strong> <span class="muted">[List your guitars]</span></p>
          <p><strong>Amplifiers:</strong> <span class="muted">[List your amps]</span></p>
          <p><strong>Pedals:</strong> <span class="muted">[List your pedalboard]</span></p>
          <p><strong>Recording setup:</strong> <span class="muted">[Interface, mics, DAW, etc.]</span></p>
        </div>
      </div>
    </div>
  </section>

  <div class="wrap"><GrainDivider /></div>

  <section class="wrap">
    <h2>Videos, performances &amp; collaborations</h2>
    <p class="prose">
      Add a new Markdown file to <span class="mono">src/content/music/</span> with a
      <span class="mono">youtubeId</span> and it appears here automatically — no page edits required.
    </p>
    <div class="grid grid-auto">
      {entries.map((e) => (
        <div class="reveal">
          <MusicCard
            title={e.data.title}
            type={e.data.type}
            date={e.data.date}
            youtubeId={e.data.youtubeId}
            platform={e.data.platform}
            duration={e.data.duration}
            description={e.data.description}
          />
        </div>
      ))}
    </div>
  </section>

  <section class="wrap">
    <h2>Upcoming performances</h2>
    <p class="muted">[Nothing scheduled yet — add dates here as they're booked.]</p>
  </section>
</BaseLayout>
